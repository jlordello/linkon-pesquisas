rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /responses/{responseId} {
      allow read, write: if true;
    }
    match /suggestions/{suggestionId} {
      allow read, write: if true;
    }
    match /candidates_config/{categoryId} {
      allow read, write: if true;
    }
    match /test/{documentId} {
      allow read, write: if true;
    }
  }
}
